# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=urban_services
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin key — required to create services via POST /api/services
# (send as the x-admin-key header). Use a long random string.
ADMIN_API_KEY=change_this_to_a_long_random_string

# On managed hosts (Render/Heroku) a single DATABASE_URL is provided
# instead of the DB_* values above.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Razorpay (Get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Email (Optional, for later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
